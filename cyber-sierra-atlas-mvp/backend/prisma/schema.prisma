datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions Session[]
  findings Finding[]
  quizzes Quiz[]
  quizSessions QuizSession[]
}

model Session {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String  @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Finding {
  id        Int     @id @default(autoincrement())
  title     String
  description String?
  severity  String  // critical, high, medium, low
  status    String  // open, in_progress, resolved
  assignedTo Int?
  user      User?   @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  capaId    Int?
  capa      CAPA?   @relation(fields: [capaId], references: [id], onDelete: SetNull)
}

model CAPA {
  id        Int     @id @default(autoincrement())
  title     String
  status    String  // draft, submitted, approved, closed
  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  findings  Finding[]
}

model AuditLog {
  id        Int     @id @default(autoincrement())
  action    String
  resource  String
  resourceId Int
  changes   String? // JSON stringified
  createdAt DateTime @default(now())
}

// CISSP Exam Analytics Models
model Question {
  id        Int     @id @default(autoincrement())
  text      String
  domain    Int     // 1-8 for CISSP domains
  topic     String  // e.g., "Defense-in-Depth", "Security Models"
  subtopics String? // JSON array of subtopic strings
  type      String  // SCENARIO, DIRECT, POLICY, TECHNICAL
  createdAt DateTime @default(now())
  responses Response[]
}

model Quiz {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Float   // Overall percentage score
  totalQuestions Int
  correctAnswers Int
  completedAt DateTime
  createdAt DateTime @default(now())
  responses Response[]
  quizSessions QuizSession[]
}

model Response {
  id        Int     @id @default(autoincrement())
  quizId    Int
  quiz      Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId Int
  question  Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedAnswer String
  isCorrect Boolean
  domain    Int     // Denormalized for fast analytics
  topic     String  // Denormalized for fast analytics
  type      String  // Denormalized for fast analytics
  createdAt DateTime @default(now())
}

model QuizSession {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizzes   Quiz[]
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime @default(now())
}

model AnalyticsCache {
  id        Int     @id @default(autoincrement())
  userId    Int
  userEmail String
  data      String  // JSON stringified analytics output
  calculatedAt DateTime
  updatedAt DateTime @updatedAt
}
